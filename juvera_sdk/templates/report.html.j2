<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Juvera ROI Report — {{ generated_at }}</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
           max-width: 960px; margin: 2rem auto; padding: 0 1rem; color: #1a1a1a; }
    h1 { margin-bottom: 0.2rem; }
    .subtitle { color: #666; margin-top: 0; }
    .hero { background: #f5f7fa; border-left: 4px solid #2d7a3e;
            padding: 1rem 1.25rem; margin: 1.5rem 0; border-radius: 4px; }
    .hero-savings { font-size: 2rem; color: #2d7a3e; font-weight: 600; }
    table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    th, td { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid #eee; }
    th { background: #fafafa; font-weight: 600; }
    .bar { background: #e6f0e8; height: 1rem; border-radius: 2px; }
    .bar-fill { background: #2d7a3e; height: 100%; border-radius: 2px; }
    .gap-callout { background: #fff8e1; border-left: 4px solid #c89a00;
                   padding: 1rem; margin: 1.5rem 0; border-radius: 4px; }
    .next-steps { background: #f0f4f8; padding: 1rem; margin-top: 2rem; border-radius: 4px; }
    code { background: #f0f0f0; padding: 0.1rem 0.3rem; border-radius: 2px; }
  </style>
</head>
<body>
  <h1>Juvera ROI Report</h1>
  <p class="subtitle">Generated {{ generated_at }} · Window: {{ window_label }}</p>

  <div class="hero">
    <div>{{ total_runs }} agent run{{ "s" if total_runs != 1 else "" }} captured · {{ window_label }}</div>
    <div class="hero-savings">{{ total_savings_fmt }} estimated savings</div>
    <div>Top workflow: <strong>{{ top_workflow }}</strong></div>
  </div>

  <h2>Per-workflow breakdown</h2>
  <table>
    <thead><tr><th>Workflow</th><th>Runs</th><th>Agent cost</th>
              <th>Est. savings</th><th>Attribution</th></tr></thead>
    <tbody>
    {% for row in by_workflow %}
      <tr>
        <td>{{ row.workflow_type }}</td>
        <td>{{ row.runs }}</td>
        <td>{{ row.agent_cost_fmt }}</td>
        <td>{{ row.savings_fmt }}</td>
        <td><div class="bar"><div class="bar-fill"
            style="width: {{ row.attribution_pct }}%"></div></div>
            {{ row.attribution_pct_fmt }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>Top issues</h2>
  {% if top_issues %}
  <table>
    <thead><tr><th>When</th><th>Agent</th><th>Issue</th></tr></thead>
    <tbody>
    {% for i in top_issues %}
      <tr><td>{{ i.captured_at }}</td><td>{{ i.agent_id }}</td><td>{{ i.issue }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p>No errors or escalations in this window.</p>
  {% endif %}

  <div class="gap-callout">
    <strong>Attribution gap:</strong>
    {{ unattributed_runs }} of {{ total_runs }} runs lack a <code>work_item_id</code>.
    These show <em>provisional</em> savings. Verify them by instrumenting
    <code>j.set_work_item(...)</code> in your agent code or by connecting a system
    of record (Zendesk, Salesforce, Stripe) to Juvera.
  </div>

  <h2>Recent runs (last 50)</h2>
  <table>
    <thead><tr><th>When</th><th>Agent</th><th>Model</th>
              <th>Tokens</th><th>Cost</th><th>Status</th></tr></thead>
    <tbody>
    {% for r in recent %}
      <tr>
        <td>{{ r.captured_at }}</td>
        <td>{{ r.agent_id }}</td>
        <td>{{ r.model }}</td>
        <td>{{ r.input_tokens }} / {{ r.output_tokens }}</td>
        <td>{{ r.agent_cost_usd_fmt }}</td>
        <td>{{ r.status }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  <div class="next-steps">
    <strong>Next steps</strong>
    <ol>
      <li>Instrument your agent: <code>pip install juvera-sdk</code> and add
          <code>j.workflow(...)</code> spans (see README).</li>
      <li>Connect a system of record so provisional ROI becomes verified ROI.</li>
      <li>Cross-team dashboards and alerts at
          <a href="https://juvera.ai">juvera.ai</a>.</li>
    </ol>
  </div>
</body>
</html>
